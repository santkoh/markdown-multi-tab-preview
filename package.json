{
  "name": "markdown-multi-tab-preview",
  "displayName": "Markdown Multi Tab Preview",
  "description": "Preview multiple Markdown files simultaneously with independent preview panels",
  "version": "0.1.0",
  "publisher": "santkoh",
  "engines": {
    "vscode": "^1.100.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/santkoh/markdown-multi-tab-preview"
  },
  "bugs": {
    "url": "https://github.com/santkoh/markdown-multi-tab-preview/issues"
  },
  "homepage": "https://github.com/santkoh/markdown-multi-tab-preview#readme",
  "icon": "media/icon.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package --no-dependencies"
  },
  "contributes": {
    "commands": [
      {
        "command": "mdMultiTabPreview.showPreview",
        "title": "Markdown Multi Tab Preview: Show Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "mdMultiTabPreview.showEditor",
        "title": "Markdown Multi Tab Preview: Show Editor",
        "icon": "$(edit)"
      },
      {
        "command": "mdMultiTabPreview.togglePreview",
        "title": "Markdown Multi Tab Preview: Toggle Preview"
      }
    ],
    "keybindings": [
      {
        "command": "mdMultiTabPreview.togglePreview",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "editorLangId == markdown || activeWebviewPanelId == mdMultiTabPreview"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "mdMultiTabPreview.showPreview",
          "when": "editorLangId == markdown",
          "group": "navigation"
        },
        {
          "command": "mdMultiTabPreview.showEditor",
          "when": "activeWebviewPanelId == mdMultiTabPreview",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Markdown Multi Tab Preview",
      "properties": {
        "mdMultiTabPreview.autoPreview": {
          "type": "boolean",
          "default": true,
          "description": ".mdファイルを開いた時にプレビューを自動表示"
        }
      }
    }
  },
  "packageManager": "pnpm@10.29.3",
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/vscode": "^1.109.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "npm-run-all2": "^8.0.4",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dompurify": "^3.3.1",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.3",
    "mermaid": "^11.12.3"
  }
}
